{
  "name": "@czap/scene",
  "version": "0.1.0",
  "description": "ECS-backed scene composition capsule for czap",
  "license": "MIT",
  "author": "The Free Battery Factory",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheFreeBatteryFactory/czap",
    "directory": "packages/scene"
  },
  "bugs": "https://github.com/TheFreeBatteryFactory/czap/issues",
  "homepage": "https://github.com/TheFreeBatteryFactory/czap#readme",
  "keywords": [
    "czap",
    "scene",
    "ecs",
    "timeline",
    "video",
    "composition",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./dev": {
      "types": "./dist/dev/server.d.ts",
      "import": "./dist/dev/server.js",
      "development": "./src/dev/server.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@czap/_spine": "workspace:*",
    "@czap/core": "workspace:*"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
