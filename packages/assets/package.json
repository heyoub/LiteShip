{
  "name": "@czap/assets",
  "version": "0.1.1",
  "description": "Asset capsules + analysis projections for czap",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/heyoub/LiteShip",
    "directory": "packages/assets"
  },
  "bugs": "https://github.com/heyoub/LiteShip/issues",
  "homepage": "https://github.com/heyoub/LiteShip#readme",
  "keywords": [
    "czap",
    "assets",
    "audio",
    "wav",
    "beat-detection",
    "waveform",
    "onset",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "development": "./src/testing.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/core": "workspace:*"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
