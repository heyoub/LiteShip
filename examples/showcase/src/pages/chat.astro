---
import Base from '../layouts/Base.astro';
---

<Base title="czap showcase -- LLM chat">
  <header class="page-header">
    <h1>Generative UI Chat</h1>
    <p>
      LLM token streams treated as adaptive media. The chat container connects
      to <code>/api/chat</code> and incrementally renders the response,
      applying boundary-driven layout as content grows.
    </p>
  </header>

  <section class="chat-demo">
    <div
      class="chat-container"
      data-czap-llm-url="/api/chat"
      data-czap-llm-mode="append"
      client:llm
    >
      <div class="chat-messages">
        <div class="chat-message chat-message--system">
          Type a message below to start a conversation.
        </div>
      </div>
      <form class="chat-input">
        <input
          type="text"
          placeholder="Ask something..."
          class="chat-input__field"
          autocomplete="off"
        />
        <button type="submit" class="chat-input__btn">Send</button>
      </form>
    </div>
  </section>
</Base>

<style>
  .page-header {
    margin-bottom: 2rem;
  }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--czap-primary, #4f46e5);
  }
  .page-header p {
    margin-top: 0.5rem;
    color: var(--czap-muted, #64748b);
    max-width: 40rem;
  }
  .page-header code {
    background: var(--czap-border, #e2e8f0);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
  }

  .chat-demo {
    margin: 2rem 0;
  }

  .chat-container {
    border: 1px solid var(--czap-border, #e2e8f0);
    border-radius: 0.75rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 32rem;
  }

  .chat-messages {
    flex: 1;
    padding: 1.5rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .chat-message {
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    max-width: 80%;
  }

  .chat-message--system {
    background: color-mix(in srgb, var(--czap-surface, #ffffff) 90%, var(--czap-muted, #64748b));
    color: var(--czap-muted, #64748b);
    font-style: italic;
    align-self: center;
    max-width: 100%;
    text-align: center;
  }

  .chat-input {
    display: flex;
    gap: 0.5rem;
    padding: 1rem;
    border-top: 1px solid var(--czap-border, #e2e8f0);
    background: var(--czap-surface, #ffffff);
  }

  .chat-input__field {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--czap-border, #e2e8f0);
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    background: var(--czap-surface, #ffffff);
    color: var(--czap-text, #1e293b);
    outline: none;
  }
  .chat-input__field:focus {
    border-color: var(--czap-primary, #4f46e5);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--czap-primary, #4f46e5) 25%, transparent);
  }

  .chat-input__btn {
    appearance: none;
    border: none;
    background: var(--czap-primary, #4f46e5);
    color: #ffffff;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .chat-input__btn:hover {
    background: color-mix(in srgb, var(--czap-primary, #4f46e5) 85%, black);
  }
</style>
